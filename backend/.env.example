# Runway
RUNWAYML_API_SECRET=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (server-side service role - keep secret!)
# Still used for Auth (JWT verification), Storage buckets, and the social/Realtime
# tables (profiles, friendships, messages) even after the Aurora migration.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Aurora PostgreSQL (core relational data: users, wardrobe_items, try_on_results, outfits)
#
# Option A - IAM auth (free-plan / "IAM only" cluster). No DB password; the backend
# mints a short-lived token per connection. Needs AWS creds + region below.
AURORA_IAM_AUTH=true
AURORA_HOST=your-cluster.cluster-xxxxx.ap-south-1.rds.amazonaws.com
AURORA_PORT=5432
AURORA_DB=postgres
AURORA_USER=postgres
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B - password auth (standard cluster). Set AURORA_IAM_AUTH=false (or unset) and use:
# AURORA_DATABASE_URL=postgresql+psycopg2://<user>:<password>@<endpoint>:5432/<db>?sslmode=require

# Anthropic (fallback chat stylist)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App config
FRONTEND_URL=http://localhost:3000
DEMO_USER_ID=demo-user-001
